# Clinical War Room - Environment Variables

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# API Keys (required for LLM phases)
GROQ_API_KEY=your_groq_api_key_here

# Safety Thresholds (DO NOT LOWER IN PRODUCTION)
MIN_CONFIDENCE_THRESHOLD=0.6
MAX_RISK_THRESHOLD=0.7

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
